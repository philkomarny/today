# Required — Claude Code uses this automatically
# ANTHROPIC_API_KEY=sk-ant-...

# Recommended — enables web scraping for intel/social/legal agents
# Get one at https://firecrawl.dev
# FIRECRAWL_API_KEY=fc-...

# Optional — enables AI image generation for social posts
# Get one at https://openrouter.ai
# OPENROUTER_API_KEY=sk-or-...

# Optional — posts Industry Intel section to a Slack channel
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional — password-protects your deployed dashboard
# VAULT_PASSPHRASE=your-passphrase-here

# Calendar credentials (configured during first-run setup)
# For Microsoft/Outlook:
# MS_CLIENT_ID=
# MS_TENANT_ID=
# MS_CLIENT_SECRET=
# MS_USER_EMAIL=

# For Google Calendar: uses Claude Code's built-in Google Calendar MCP
